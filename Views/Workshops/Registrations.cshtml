@model IEnumerable<Lab3.Models.Rsvp>

@{
    ViewData["Title"] = "Registrations";
}

<h1>Workshop Registrations</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Workshop</th>
            <th>Needs Accommodation</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>@item.WorkshopTitle</td>
                <td>@(item.NeedsAccommodation ? "Yes" : "No")</td>
            </tr>
        }
    </tbody>
</table>