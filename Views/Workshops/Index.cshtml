@{
    ViewData["Title"] = "Workshop RSVP";
}

<h1>Workshop RSVP Feature</h1>
<p>Welcome! Use this tool to register for our upcoming technical workshops. You can fill out the form or view existing registrations below.</p>

<div class="mt-4">
    <a asp-action="RsvpForm" class="btn btn-primary">Register Now</a>
    <a asp-action="Registrations" class="btn btn-secondary">View All RSVPs</a>
</div>